#!/usr/bin/env bash
# reflection — unified CLI for agent self-reflection
# Usage: reflection <command> [args...]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  check)   exec "$SCRIPT_DIR/check.sh" "$@" ;;
  log)     exec "$SCRIPT_DIR/log.sh" "$@" ;;
  read)    exec "$SCRIPT_DIR/read.sh" "$@" ;;
  stats)   exec "$SCRIPT_DIR/stats.sh" "$@" ;;
  promote) exec "$SCRIPT_DIR/promote.sh" "$@" ;;
  demote)  exec "$SCRIPT_DIR/demote.sh" "$@" ;;
  apply)   exec "$SCRIPT_DIR/apply.sh" "$@" ;;
  help|--help|-h)
    echo "Usage: reflection <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  check [--quiet]              Check if reflection is due"
    echo "  log <tag> <miss> <fix>       Log a new reflection"
    echo "  read [n] [--tag <tag>]       Read recent reflections"
    echo "  stats                        Show memory statistics"
    echo "  promote <pattern>             Promote a pattern up one layer"
    echo "  demote <pattern>              Demote a pattern down one layer"
    echo "  apply <pattern>               Record successful pattern application"
    echo ""
    echo "Three-layer memory:"
    echo "  Layer 1 (Golden Rules)  → SOUL.md (≤50 rules, always loaded)"
    echo "  Layer 2 (Active)        → memory/self-review.md (≤100 lines, by topic)"
    echo "  Layer 3 (Raw Log)       → memory/YYYY-MM-DD.md (daily entries)"
    ;;
  *)
    echo "Unknown command: $CMD" >&2
    echo "Run 'reflection help' for usage." >&2
    exit 1
    ;;
esac
