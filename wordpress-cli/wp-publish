# WordPress 发布助手 - 聊天指令直接发布
# 用法: wp-publish <文件路径> [draft|publish]

WP_URL="mingfang.tech"
WP_USER="mfang0126@gmail.com"
WP_PASS="X5YpiLJQAAbZyayYYfEXyw7O"

# 检查参数
if [ $# -lt 1 ]; then
    echo "用法: wp-publish <markdown文件> [draft|publish]"
    echo "示例: wp-publish article.md draft"
    exit 1
fi

FILE="$1"
STATUS="${2:-draft}"

# 检查文件
if [ ! -f "$FILE" ]; then
    echo "❌ 文件不存在: $FILE"
    exit 1
fi

echo "📝 正在发布: $FILE"
echo "📤 状态: $STATUS"

# 提取标题（第一行 # 开头）
TITLE=$(head -20 "$FILE" | grep "^# " | head -1 | sed 's/^# //')

# 使用 Node.js 脚本发布
node /Users/mingfang/.openclaw/workspace/skills/wordpress-cli/publish.js "$FILE" "$STATUS" "$TITLE"
